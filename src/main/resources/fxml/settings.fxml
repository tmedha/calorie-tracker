<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" styleClass="scroll-pane"
            xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml">
    <VBox styleClass="content" spacing="8">
        <Label text="Settings" styleClass="page-title"/>
        <Label text="Preferences for how the app displays your data." styleClass="page-subtitle"/>

        <VBox styleClass="card" spacing="16" maxWidth="520">
            <Label text="Display units" styleClass="section-title"/>
            <VBox spacing="4">
                <Label text="Measurement system" styleClass="field-label"/>
                <ComboBox fx:id="unitCombo" maxWidth="260"/>
            </VBox>
            <Label fx:id="unitHint" styleClass="muted" wrapText="true"/>
        </VBox>

        <HBox spacing="12" alignment="CENTER_LEFT">
            <Button text="Save preferences" styleClass="primary-button" onAction="#save"/>
            <Label fx:id="statusLabel" styleClass="muted"/>
        </HBox>
    </VBox>
</ScrollPane>
