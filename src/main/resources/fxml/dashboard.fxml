<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import com.calorietracker.ui.controls.CalorieRing?>

<ScrollPane fitToWidth="true" styleClass="scroll-pane"
            xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml">
    <VBox styleClass="content" spacing="18">

        <!-- Header + date navigator -->
        <HBox alignment="CENTER_LEFT" spacing="12">
            <VBox spacing="2">
                <Label text="Dashboard" styleClass="page-title"/>
                <Label fx:id="dateSubtitle" styleClass="page-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="‹" styleClass="icon-button" onAction="#previousDay"/>
            <DatePicker fx:id="datePicker" prefWidth="160"/>
            <Button text="›" styleClass="icon-button" onAction="#nextDay"/>
            <Button text="Today" styleClass="ghost-button" onAction="#goToday"/>
        </HBox>

        <!-- Daily summary -->
        <VBox styleClass="hero-card" spacing="14">
            <HBox alignment="CENTER_LEFT">
                <Label text="Calories eaten" styleClass="summary-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox fx:id="streakChip" styleClass="streak-chip" alignment="CENTER" spacing="6">
                    <Label fx:id="streakLabel" styleClass="streak-count"/>
                </HBox>
            </HBox>

            <HBox spacing="36" alignment="CENTER_LEFT">
                <VBox spacing="8" alignment="CENTER" minWidth="180">
                    <CalorieRing fx:id="calorieRing"/>
                    <Label fx:id="caloriesSub" styleClass="summary-label"/>
                </VBox>

                <VBox spacing="12" HBox.hgrow="ALWAYS">
                    <VBox spacing="4">
                        <HBox>
                            <Label text="Protein" styleClass="macro-name"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="proteinLabel" styleClass="entry-meta"/>
                        </HBox>
                        <ProgressBar fx:id="proteinBar" progress="0" maxWidth="Infinity"
                                     styleClass="protein-bar"/>
                    </VBox>
                    <VBox spacing="4">
                        <HBox>
                            <Label text="Carbs" styleClass="macro-name"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="carbsLabel" styleClass="entry-meta"/>
                        </HBox>
                        <ProgressBar fx:id="carbsBar" progress="0" maxWidth="Infinity"
                                     styleClass="carbs-bar"/>
                    </VBox>
                    <VBox spacing="4">
                        <HBox>
                            <Label text="Fat" styleClass="macro-name"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="fatLabel" styleClass="entry-meta"/>
                        </HBox>
                        <ProgressBar fx:id="fatBar" progress="0" maxWidth="Infinity"
                                     styleClass="fat-bar"/>
                    </VBox>
                </VBox>
            </HBox>
        </VBox>

        <!-- Meal sections (populated by the controller) -->
        <VBox fx:id="mealsBox" spacing="14"/>
    </VBox>
</ScrollPane>
