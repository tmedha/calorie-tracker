<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" styleClass="scroll-pane"
            xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml">
    <VBox styleClass="content" spacing="18">
        <VBox spacing="2">
            <Label text="Trends" styleClass="page-title"/>
            <Label text="Your calorie history and weight over time." styleClass="page-subtitle"/>
        </VBox>

        <!-- Weekly calories -->
        <VBox styleClass="card" spacing="10">
            <Label text="Last 7 days" styleClass="section-title"/>
            <Label fx:id="weeklyCaption" styleClass="muted"/>
            <VBox fx:id="weeklyChartHolder" minHeight="240"/>
        </VBox>

        <!-- Weight tracking -->
        <VBox styleClass="card" spacing="12">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Weight" styleClass="section-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Log today:" styleClass="muted"/>
                <TextField fx:id="weightField" prefWidth="90"/>
                <Label fx:id="weightUnitLabel" styleClass="muted"/>
                <Button text="Log weight" styleClass="primary-button" onAction="#logWeight"/>
            </HBox>

            <HBox spacing="12">
                <VBox styleClass="stat-tile" spacing="2" minWidth="150">
                    <Label fx:id="latestValue" styleClass="stat-tile-value" text="—"/>
                    <Label text="Latest weight" styleClass="stat-tile-label"/>
                </VBox>
                <VBox styleClass="stat-tile" spacing="2" minWidth="150">
                    <Label fx:id="changeValue" styleClass="stat-tile-value" text="—"/>
                    <Label text="Net change" styleClass="stat-tile-label"/>
                </VBox>
            </HBox>

            <VBox fx:id="weightChartHolder" minHeight="260"/>
            <Label fx:id="weightEmptyHint" styleClass="empty-hint"
                   text="No weight logged yet. Enter today's weight above to start tracking."/>
        </VBox>
    </VBox>
</ScrollPane>
